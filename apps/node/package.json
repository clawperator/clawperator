{
  "name": "clawperator",
  "version": "0.1.4",
  "description": "Clawperator Node API - reliable Android execution for LLM agents",
  "type": "module",
  "main": "dist/cli/index.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/clawpilled/clawperator.git",
    "directory": "apps/node"
  },
  "homepage": "https://clawperator.com",
  "bugs": "https://github.com/clawpilled/clawperator/issues",
  "bin": "dist/cli/index.js",
  "publishConfig": {
    "access": "public",
    "tag": "latest"
  },
  "files": [
    "dist/",
    "!dist/test/**",
    "!dist/**/*.map",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/cli/index.js",
    "test": "node --test dist/test/**/*.test.js",
    "test:unit": "node --test dist/test/unit/**/*.test.js",
    "lint": "eslint src --ext .ts"
  },
  "keywords": [
    "clawperator",
    "openclaw",
    "android",
    "automation",
    "agent"
  ],
  "license": "Apache-2.0",
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^22.10.0",
    "typescript": "^5.7.0"
  },
  "dependencies": {
    "express": "^5.2.1",
    "zod": "^3.24.0"
  }
}
