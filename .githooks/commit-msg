#!/usr/bin/env bash
set -euo pipefail

if [[ $# -ne 1 ]]; then
  echo "usage: $0 <commit-message-file>" >&2
  exit 1
fi

message_file="$1"

if [[ ! -f "$message_file" ]]; then
  echo "commit message file not found: $message_file" >&2
  exit 1
fi

repo_root="$(cd "$(dirname "$0")/.." && pwd)"
policy_file="$repo_root/validation/commit_message_policy.sh"
if [[ ! -f "$policy_file" ]]; then
  echo "commit message policy file not found: $policy_file" >&2
  exit 1
fi
# shellcheck source=/dev/null
source "$policy_file"

lines=()
while IFS= read -r line || [[ -n "$line" ]]; do
  if is_forbidden_attribution_line "$line"; then
    continue
  fi
  lines+=("$line")
done < "$message_file"

# Normalize trailing blank lines after stripping forbidden trailers.
while (( ${#lines[@]} > 0 )); do
  last_index=$(( ${#lines[@]} - 1 ))
  if [[ "${lines[$last_index]}" =~ ^[[:space:]]*$ ]]; then
    unset "lines[$last_index]"
    continue
  fi
  break
done

{
  for line in "${lines[@]}"; do
    printf '%s\n' "$line"
  done
} > "$message_file"
